@model Exam.Dtos.LessonDtos.GetByIdLessonDto

@{
    ViewData["Title"] = "Dərsi Sil";
}

<h2>Dərsi Sil</h2>
<h4 class="text-danger">Bu dərsi silmək istədiyinizə əminsiniz?</h4>
<hr />

<div>
    <dl class="row">
        <dt class="col-sm-3">Dərs Kodu</dt>
        <dd class="col-sm-9">@Model.LessonCode</dd>

        <dt class="col-sm-3">Dərs Adı</dt>
        <dd class="col-sm-9">@Model.LessonName</dd>

        <dt class="col-sm-3">Sinif</dt>
        <dd class="col-sm-9">@Model.ClassLevel</dd>

        <dt class="col-sm-3">Müəllim</dt>
        <dd class="col-sm-9">@Model.TeacherName @Model.TeacherSurname</dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="Id" />
        <input type="submit" value="Bəli, Sil" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Xeyr, Ləğv Et</a>
    </form>
</div>