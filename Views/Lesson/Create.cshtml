@model Exam.Dtos.LessonDtos.CreateLessonDto;

@{
    ViewData["Title"] = "Yeni Dərs";
}

<h2>Yeni Dərs Qeydiyyatı</h2>
<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label asp-for="LessonCode" class="control-label">Dərsin Kodu</label>
                <input asp-for="LessonCode" class="form-control" placeholder="Məs: MAT" />
                <span asp-validation-for="LessonCode" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="LessonName" class="control-label">Dərsin Adı</label>
                <input asp-for="LessonName" class="form-control" />
                <span asp-validation-for="LessonName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="ClassLevel" class="control-label">Sinif</label>
                <input asp-for="ClassLevel" class="form-control" type="number" />
                <span asp-validation-for="ClassLevel" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="TeacherName" class="control-label">Müəllimin Adı</label>
                <input asp-for="TeacherName" class="form-control" />
                <span asp-validation-for="TeacherName" class="text-danger"></span>
            </div>
            <div class="form-group mb-3">
                <label asp-for="TeacherSurname" class="control-label">Müəllimin Soyadı</label>
                <input asp-for="TeacherSurname" class="form-control" />
                <span asp-validation-for="TeacherSurname" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Yadda Saxla" class="btn btn-success" />
                <a asp-action="Index" class="btn btn-secondary">Geriyə Qayıt</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}